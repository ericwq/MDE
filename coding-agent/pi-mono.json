{
  "extends": "default",
  "meta": {
    "name": "pi-mono"
  },
  "groups": {
    "include": [
      "node_runtime"
    ]
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "allow": [
      "$HOME/.pi/agent/",
      "$HOME/dev/projects/"
    ],
    "read": [
    ]
  },
  "unsafe_macos_seatbelt_rules": ["(allow user-preference-read)"]
}
